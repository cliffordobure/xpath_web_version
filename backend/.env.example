PORT=3000
MONGODB_URI=mongodb://localhost:27017/xpath_lims
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Optional: email report to client (Reports → Email to client)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@xpathlabs.local

# Optional: require API key for scanner slide upload (POST /api/public/slide-image). If unset, upload is allowed without key.
# SCANNER_API_KEY=your-scanner-api-key
